# たより — 環境設定のひな形
# 使い方：このファイルを「.env」という名前でコピーし、値を自分のものに置き換える。
#   cp .env.example .env
# .env は .gitignore 済みなので GitHub には上がりません。
# アプリ起動時（run.py / gunicorn どちらでも）に自動で読み込まれます。

# --- AIの「過去の自分」対話を有効にするのに必須の2つ ---
# ① 外部通信をONにする（これが無いとAIは一切呼ばれず定型文になる）
TAYORI_ENABLE_NETWORK=1

GEMINI_API_KEY=ここに自分の鍵を貼る（AIzaSy… または AQ.… で始まる）

# --- 任意 ---
# 使うGeminiモデル（未指定なら gemini-2.0-flash）。404が出るときはここを変える
# TAYORI_GEMINI_MODEL=gemini-2.0-flash
# Geminiの代わりに Anthropic Claude（有料）を使う場合だけ設定
# ANTHROPIC_API_KEY=sk-ant-...
